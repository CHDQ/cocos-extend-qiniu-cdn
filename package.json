{
  "package_version": 2,
  "name": "qiniu-upload",
  "version": "1.1.0",
  "description": "Cocos 构建完成后将 remote/ 远程资源自动上传到七牛云",
  "author": "DreamAbyssSurvivors",
  "editor": ">=3.7.0",
  "main": "./main.js",
  "panels": {
